generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CommunityRole {
  ADMIN
  MODERATOR
  MEMBER
}

enum NotificationType {
  YEAH_POST
  YEAH_COMMENT
  COMMENT
  FOLLOW
}

enum ReportStatus {
  PENDING
  REVIEWED
  ACTION_TAKEN
  DISMISSED
}

enum ReportReason {
  SPAM
  HARASSMENT
  HATE_SPEECH
  NSFW
  VIOLENCE
  IMPERSONATION
  MISINFORMATION
  OTHER
}

model User {
  id           String        @id @default(uuid())
  username     String        @unique
  displayName  String
  bio          String?
  avatarUrl    String?
  email        String        @unique
  password     String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  accounts     Account[]
  posts        Post[]
  comments     Comment[]
  yeahs        Yeah[]
  communities  CommunityMember[]
  followers    Follow[]      @relation("UserFollowers")
  following    Follow[]      @relation("UserFollowing")
  notifications Notification[] @relation("NotificationRecipient")
  sentNotifications Notification[] @relation("NotificationSender")
  reportsMade  Report[]      @relation("ReportReporter")
  reportsAgainst Report[]    @relation("ReportTargetUser")
}

model Account {
  id                String   @id @default(uuid())
  userId            String
  provider          String
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Community {
  id          String            @id @default(uuid())
  name        String
  description String?
  iconUrl     String?
  bannerUrl   String?
  gameTitle   String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  members     CommunityMember[]
  posts       Post[]
}

model CommunityMember {
  userId      String
  communityId String
  role        CommunityRole @default(MEMBER)
  joinedAt    DateTime      @default(now())
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  community   Community     @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@id([userId, communityId])
  @@index([communityId])
}

model Post {
  id          String    @id @default(uuid())
  content     String?
  imageUrl    String?
  drawingUrl  String?
  isSpoiler   Boolean   @default(false)
  authorId    String
  communityId String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  comments    Comment[]
  yeahs       Yeah[]
  notifications Notification[]
  reports     Report[]

  @@index([communityId, createdAt])
  @@index([authorId])
}

model Comment {
  id            String    @id @default(uuid())
  content       String
  authorId      String
  postId        String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  author        User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  post          Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  yeahs         Yeah[]
  notifications Notification[]
  reports       Report[]

  @@index([postId, createdAt])
  @@index([authorId])
}

model Yeah {
  id        String    @id @default(uuid())
  userId    String
  postId    String?
  commentId String?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post?     @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment   Comment?  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@unique([userId, commentId])
  @@index([postId])
  @@index([commentId])
  @@index([userId, createdAt])
}

model Follow {
  followerId String
  followingId String
  createdAt  DateTime @default(now())
  follower   User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following  User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@index([followingId])
}

model Notification {
  id        String           @id @default(uuid())
  type      NotificationType
  userId    String
  fromId    String
  postId    String?
  commentId String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  from      User             @relation("NotificationSender", fields: [fromId], references: [id], onDelete: Cascade)
  post      Post?            @relation(fields: [postId], references: [id], onDelete: SetNull)
  comment   Comment?         @relation(fields: [commentId], references: [id], onDelete: SetNull)

  @@index([userId, read, createdAt])
  @@index([fromId, createdAt])
}

model Report {
  id              String       @id @default(uuid())
  reporterId      String
  targetUserId    String?
  postId          String?
  commentId       String?
  reason          ReportReason
  details         String?
  status          ReportStatus @default(PENDING)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  reporter        User         @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  targetUser      User?        @relation("ReportTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)
  post            Post?        @relation(fields: [postId], references: [id], onDelete: SetNull)
  comment         Comment?     @relation(fields: [commentId], references: [id], onDelete: SetNull)

  @@index([reporterId, createdAt])
  @@index([targetUserId, createdAt])
  @@index([postId, createdAt])
  @@index([commentId, createdAt])
  @@index([status, createdAt])
}
